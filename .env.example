# .env.example  isp_manager


# 1. APLICAÇÃO - development | staging | production
# Afeta nível de log, debug do FastAPI, CORS, e cookies seguros.
APP_ENV=development

# Nome interno da aplicação. Usado em logs estruturados e métricas.
APP_NAME=isp_manager

# Versão da aplicação.
APP_VERSION=0.1.0

# DEBUG | INFO | WARNING | ERROR | CRITICAL, DEBUG só em dev. Em produção, INFO ou WARNING.
LOG_LEVEL=INFO

# console legível
LOG_FORMAT=json

# Timezone padrão da aplicação. o BANCO armazena tudo em UTC.
TZ=America/Sao_Paulo


# POSTGRES defesa em profundidade, a aplicação NUNCA conecta como superuser.
# Conexão básica compartilhada pelos dois roles.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=isp_manager

# Role da aplicação (runtime).
POSTGRES_APP_USER=isp_app
POSTGRES_APP_PASSWORD=trocar_em_producao_use_openssl_rand_hex_24

# Role de migrations (Alembic).
POSTGRES_MIGRATOR_USER=isp_migrator
POSTGRES_MIGRATOR_PASSWORD=trocar_em_producao_use_openssl_rand_hex_24

# Superuser (usado para inicializar o banco e criar os outros roles).
# Em produção, deve ser rotacionado e idealmente desativado após bootstrap.
POSTGRES_ROOT_USER=postgres
POSTGRES_ROOT_PASSWORD=trocar_em_producao_use_openssl_rand_hex_24

# Pool de conexões da API (SQLAlchemy async).
# pool_size: conexões persistentes
DB_POOL_SIZE=10
# max_overflow: extras sob picos.
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Timeout de statements SQL.
DB_STATEMENT_TIMEOUT_MS=30000


# REDIS
# /0 cache geral da aplicação
# /1 broker do Celery (filas de tarefas)
# /2 backend de resultados do Celery
REDIS_HOST=redis
REDIS_PORT=6379

# Senha do Redis. Em dev pode ficar vazia; em produção é OBRIGATÓRIA.
REDIS_PASSWORD=

REDIS_CACHE_DB=0
REDIS_BROKER_DB=1
REDIS_RESULT_DB=2


# API (FastAPI)
API_HOST=0.0.0.0
API_PORT=8000

# Chave usada para assinar JWT e tokens de sessão.
API_SECRET_KEY=trocar_obrigatoriamente_gerar_com_openssl_rand_hex_32

# Algoritmo de assinatura do JWT.
JWT_ALGORITHM=HS256

# Tempo de vida dos tokens (em minutos).
# Access token: curto, pra reduzir impacto se vazar.
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token: longo, mas pode ser revogado via app_user_session.
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# CORS: origens permitidas (separadas por vírgula).
CORS_ORIGINS=http://localhost:3000

# Tamanho máximo do corpo de requisição (Bytes).
MAX_REQUEST_SIZE=1048576

# Habilita docs interativos (/docs e /redoc).
ENABLE_API_DOCS=true


# CELERY (worker assíncrono)

# URLs derivadas das vars do Redis acima.
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Concorrência: quantas tasks rodam simultaneamente por worker.
CELERY_WORKER_CONCURRENCY=4

# Limite de tasks por processo antes de reciclar (previne vazamento de memória).
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# Timeout duro pra qualquer task (em segundos).
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=540


# FRONTEND (Next.js)

# URL pública da API.
NEXT_PUBLIC_API_URL=http://localhost:8000

# URL interna usada por server-side (SSR/SSG dentro do container).
# Em Docker, resolve pelo nome do serviço.
INTERNAL_API_URL=http://api:8000


# ADAPTERS DE INFRAESTRUTURA

# Cofre de segredos: env | vault
# env:   lê de variáveis de ambiente (dev/staging)
# vault: HashiCorp Vault (produção)
SECRETS_BACKEND=env

# Configuração do Vault (usada se SECRETS_BACKEND=vault).
VAULT_ADDR=
VAULT_TOKEN=
VAULT_MOUNT_PATH=secret/isp_manager


# ACESSO A EQUIPAMENTOS (OLT), nenhuma senha de OLT aparece aqui.

# Timeout padrão de SSH em segundos.
OLT_SSH_TIMEOUT=15
OLT_TELNET_TIMEOUT=15

# Tentativas em caso de falha de conexão.
OLT_CONNECT_RETRIES=3

# Tamanho máximo de saída SSH/Telnet capturada (bytes).
OLT_MAX_OUTPUT_BYTES=10485760


# INTEGRAÇÃO IXC

IXC_BASE_URL=
IXC_API_TOKEN=
IXC_ENABLED=false


# OBSERVABILIDADE

# Habilita coleta de métricas Prometheus em /metrics.
METRICS_ENABLED=true

# Habilita tracing distribuído (OpenTelemetry).
TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=


# PARTIÇÕES E MANUTENÇÃO

# Quantos meses à frente manter partições de optical_reading criadas.
# Cron mensal cria a próxima partição; este buffer evita queda em "default".
OPTICAL_PARTITION_BUFFER_MONTHS=12

# Política de retenção de partições antigas (em meses).
OPTICAL_PARTITION_RETENTION_MONTHS=0

# DOCKER / POSTGRES

# Superusuário do Postgres, usado APENAS pelo init.sh para criar os roles.
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=changeme_super

# Database alvo.
POSTGRES_DB=isp_manager

# Role de runtime da aplicação (FastAPI + Celery).
ISP_APP_DB_USER=isp_app
ISP_APP_DB_PASSWORD=changeme_app

# Role do Alembic (migrações).
ISP_MIGRATOR_DB_USER=isp_migrator
ISP_MIGRATOR_DB_PASSWORD=changeme_migrator

# Hosts internos usados pela api/worker dentro da rede do compose.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379

# FRONTEND

NEXT_PUBLIC_API_URL=http://localhost:8000