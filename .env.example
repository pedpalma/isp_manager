# ==> Variáveis de ambiente

# --> Ambiente <--
# development, staging, production
ENVIRONMENT=development

# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG
TZ=America/Sao_Paulo

# --> Postgres <--
POSTGRES_USER=isp_app
POSTGRES_PASSWORD=changeme_in_local_env
POSTGRES_DB=isp_manager
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# URLs derivadas: a API usa async, o worker usa sync.
DATABASE_URL_ASYNC=postgresql+asyncpg://isp_app:changeme_in_local_env@postgres:5432/isp_manager
DATABASE_URL_SYNC=postgresql+psycopg://isp_app:changeme_in_local_env@postgres:5432/isp_manager

# Role separado para o Alembic rodar migrations.
DATABASE_URL_MIGRATIONS=postgresql+psycopg://isp_app:changeme_in_local_env@postgres:5432/isp_manager

# --> Redis <--
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# --> Celery <--
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_DEFAULT_QUEUE=default

# --> API <--
API_HOST=0.0.0.0
API_PORT=8000
# somente em dev
API_RELOAD=true
API_CORS_ORIGINS=http://localhost:3000
API_SECRET_KEY=change_me_to_a_long_random_string_min_32_chars
API_JWT_ALGORITHM=HS256
API_JWT_EXPIRES_MINUTES=60

# --> Frontend <--
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_TELEMETRY_DISABLED=1

# --> Cofre de segredos, para credenciais de OLT <--
# Em dev: env_store; prod: vault_store.
# env | vault
SECRETS_BACKEND=env
VAULT_ADDR=
VAULT_TOKEN=

# --> UID/GID para containers <--
# Rode no host: `id -u` e `id -g` e preencha aqui.
UID=1000
GID=1000