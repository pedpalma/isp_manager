# .env.example — isp_manager
# Copie para .env e ajuste as senhas antes de subir o ambiente.
# Em produção, NENHUMA senha real deve viver neste arquivo.


# 1. APLICAÇÃO

# Ambiente: development | staging | production
# Afeta nível de log, debug do FastAPI, CORS e cookies seguros.
APP_ENV=development

# Nome interno da aplicação. Aparece em logs estruturados e métricas.
APP_NAME=isp_manager

# Versão da aplicação.
APP_VERSION=0.1.0

# DEBUG | INFO | WARNING | ERROR | CRITICAL. DEBUG só em dev.
LOG_LEVEL=INFO

# json | console (console = legível em terminal, json = produção)
LOG_FORMAT=json

# Timezone da aplicação. O banco SEMPRE armazena em UTC.
TZ=America/Sao_Paulo


# 2. POSTGRES — defesa em profundidade
# A aplicação NUNCA conecta como superuser. São três roles distintos:
#   - SUPERUSER: usado APENAS pelo init.sh para criar os outros roles
#   - ISP_APP_DB_USER: runtime da API/worker (SELECT/INSERT/UPDATE/DELETE)
#   - ISP_MIGRATOR_DB_USER: apenas Alembic (CREATE/ALTER/DROP)

# Hosts internos resolvidos pela rede do compose.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=isp_manager

# Superuser do Postgres (apenas para inicialização do banco).
# Em produção, rotacionar após bootstrap e idealmente desativar.
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=changeme_super

# Role da aplicação (FastAPI + Celery).
ISP_APP_DB_USER=isp_app
ISP_APP_DB_PASSWORD=changeme_app

# Role do Alembic (migrações).
ISP_MIGRATOR_DB_USER=isp_migrator
ISP_MIGRATOR_DB_PASSWORD=changeme_migrator

# Pool de conexões da API (SQLAlchemy async).
# pool_size: conexões persistentes mantidas abertas.
DB_POOL_SIZE=10
# max_overflow: conexões extras criadas sob pico.
DB_MAX_OVERFLOW=20
# Timeout (s) para esperar uma conexão livre do pool.
DB_POOL_TIMEOUT=30
# Recicla conexões a cada N segundos (evita timeouts do servidor).
DB_POOL_RECYCLE=1800

# Timeout duro de cada statement SQL (ms).
DB_STATEMENT_TIMEOUT_MS=30000

# Loga todo SQL no stdout (útil em dev, JAMAIS em prod — vaza dados).
DB_ECHO_SQL=false


# 3. REDIS
# /0 cache geral da aplicação
# /1 broker do Celery (filas)
# /2 backend de resultados do Celery

REDIS_HOST=redis
REDIS_PORT=6379

# Em dev pode ficar vazia; em produção é OBRIGATÓRIA.
REDIS_PASSWORD=

REDIS_CACHE_DB=0
REDIS_BROKER_DB=1
REDIS_RESULT_DB=2


# 4. API (FastAPI)

API_HOST=0.0.0.0
API_PORT=8000

# Chave para assinar JWT e tokens de sessão.
# Gere com: openssl rand -hex 32  (ou: make secret)
API_SECRET_KEY=trocar_obrigatoriamente_gerar_com_openssl_rand_hex_32

JWT_ALGORITHM=HS256

# Tempo de vida (minutos).
# Access token: curto, para limitar impacto se vazar.
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token: longo, mas revogável via app_user_session.
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# CORS: origens permitidas (separadas por vírgula).
CORS_ORIGINS=http://localhost:3000

# Tamanho máximo de body (bytes).
MAX_REQUEST_SIZE=1048576

# Habilita /docs e /redoc.
ENABLE_API_DOCS=true


# 5. CELERY

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=540


# 6. FRONTEND (Next.js)

# URL pública (consumida pelo navegador).
NEXT_PUBLIC_API_URL=http://localhost:8000
# URL interna (SSR dentro do container).
INTERNAL_API_URL=http://api:8000


# 7. ADAPTERS DE INFRAESTRUTURA

# Cofre de segredos: env | vault
#   env:   variáveis de ambiente (dev/staging)
#   vault: HashiCorp Vault (produção)
SECRETS_BACKEND=env

VAULT_ADDR=
VAULT_TOKEN=
VAULT_MOUNT_PATH=secret/isp_manager


# 8. ACESSO A EQUIPAMENTOS (OLT)
# Nenhuma senha de OLT aparece aqui — só timeouts e limites.

OLT_SSH_TIMEOUT=15
OLT_TELNET_TIMEOUT=15
OLT_CONNECT_RETRIES=3
OLT_MAX_OUTPUT_BYTES=10485760


# 9. INTEGRAÇÃO IXC

IXC_BASE_URL=
IXC_API_TOKEN=
IXC_ENABLED=false


# 10. OBSERVABILIDADE

METRICS_ENABLED=true
TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=


# 11. PARTIÇÕES E MANUTENÇÃO

# Buffer de partições futuras de optical_reading.
OPTICAL_PARTITION_BUFFER_MONTHS=12
# Retenção de partições antigas (0 = nunca apaga).
OPTICAL_PARTITION_RETENTION_MONTHS=0