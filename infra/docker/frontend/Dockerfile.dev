# Next.js (dev): instala dependências em camada cacheada; o código entra por bind mount.

FROM node:22-bookworm-slim AS dev

    # Explícito, next dev assume mesmo
ENV NODE_ENV=development \
    # Desativa coleta de telemetria do Next
    NEXT_TELEMETRY_DISABLED=1 \
    # Faz npm/pnpm/yarn pularem prompts interativos
    CI=true

# Dependências de sistema mínimas.
# curl é usado pelo healthcheck do container (ver docker-compose).
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        tini \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ----- Camada de dependências -----
# Copia SÓ os manifestos e instala. Esta camada fica em cache enquanto
# package.json / package-lock.json não mudarem, deixando o rebuild rápido
# quando só o código-fonte muda.
#
# O contexto de build é a raiz do repositório (ver docker-compose), por isso
# os caminhos começam em "frontend/".
#
# npm ci exige o package-lock.json e instala EXATAMENTE o que está travado nele
# (instalação reprodutível). Na primeira subida, o conteúdo de /app/node_modules
# desta camada é copiado para o volume nomeado frontend_node_modules.
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

# Em dev NÃO copiamos o restante do código: ele entra por bind mount
# (./frontend:/app no compose), preservando o hot reload.

# Encaminhamento correto de SIGTERM (graceful shutdown do next dev).
ENTRYPOINT ["/usr/bin/tini", "--"]

# O compose pode sobrescrever se quiser passar flags.
CMD ["npm", "run", "dev"]
