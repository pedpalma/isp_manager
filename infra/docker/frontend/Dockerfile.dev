# Next.js 15 em modo desenvolvimento.

FROM node:22-bookworm-slim AS dev

    # Explícito, next dev assume mesmo
ENV NODE_ENV=development \
    # Desativa coleta de telemetria do Next
    NEXT_TELEMETRY_DISABLED=1 \
    # Faz npm/pnpm/yarn pularem prompts interativos
    CI=true

# Dependências de sistema mínimas. 
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        tini \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY frontend/package.jso[n] frontend/package-lock.jso[n] /app/
RUN if [ -f /app/package.json ]; then \
        npm ci || npm install; \
    else \
        echo "[frontend dev] package.json ainda não existe (esperado até Marco 7)."; \
    fi

# Encaminhamento correto de SIGTERM (graceful shutdown do next dev).
ENTRYPOINT ["/usr/bin/tini", "--"]

# O compose pode sobrescrever se quiser passar flags.
CMD ["npm", "run", "dev"]